#!/usr/bin/env bash
set -euo pipefail

# Wrapper to locate the lspmux-cc-mcp binary built by cargo.

die() { printf 'ERROR: %s\n' "$*" >&2; exit 1; }

: "${LSPMUX_CLIENT_KIND:=claude_mcp}"
: "${LSPMUX_CLIENT_HOST:=claude}"
: "${LSPMUX_SESSION_ID:=claude-mcp-$$-$(date +%s)}"

export LSPMUX_CLIENT_KIND
export LSPMUX_CLIENT_HOST
export LSPMUX_SESSION_ID

_SELF="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")"
_PLUGIN_CANDIDATE="${CLAUDE_PLUGIN_ROOT:-}/bin/lspmux-cc-mcp"
if [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -x "${_PLUGIN_CANDIDATE}" ] && [ "${_PLUGIN_CANDIDATE}" != "${_SELF}" ]; then
    MCP_BIN="${_PLUGIN_CANDIDATE}"
elif [ -n "${LSPMUX_MCP_PATH:-}" ] && [ -x "${LSPMUX_MCP_PATH}" ]; then
    MCP_BIN="${LSPMUX_MCP_PATH}"
elif command -v lspmux-cc-mcp >/dev/null 2>&1; then
    MCP_BIN="$(command -v lspmux-cc-mcp)"
else
    CARGO_HOME="${CARGO_HOME:-$HOME/.cargo}"
    MCP_BIN="${CARGO_HOME}/bin/lspmux-cc-mcp"
    # Try nix result as last resort
    if [ ! -x "${MCP_BIN}" ]; then
        SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
        NIX_RESULT="${SCRIPT_DIR}/result/bin/lspmux-cc-mcp"
        if [ -x "${NIX_RESULT}" ]; then
            MCP_BIN="${NIX_RESULT}"
        fi
    fi
fi

if [ ! -x "${MCP_BIN}" ]; then
    printf '%s\n' "Build with: cargo install --path mcp-server" >&2
    printf '%s\n' "Or set LSPMUX_MCP_PATH to the binary location" >&2
    die "lspmux-cc-mcp not found"
fi

exec "${MCP_BIN}" "$@"
