#!/usr/bin/env bash
set -euo pipefail

# Wrapper to locate the lspmux binary installed by cargo.

die() { printf 'ERROR: %s\n' "$*" >&2; exit 1; }

export LSPMUX_CLIENT_KIND="${LSPMUX_CLIENT_KIND:-claude_lsp}"
export LSPMUX_CLIENT_HOST="${LSPMUX_CLIENT_HOST:-claude}"
export LSPMUX_SESSION_ID="${LSPMUX_SESSION_ID:-claude-lsp-$$-$(date +%s)}"

if [ -n "${LSPMUX_PATH:-}" ] && [ -x "${LSPMUX_PATH}" ]; then
    LSPMUX_BIN="${LSPMUX_PATH}"
elif command -v lspmux >/dev/null 2>&1; then
    LSPMUX_BIN="$(command -v lspmux)"
else
    CARGO_HOME="${CARGO_HOME:-$HOME/.cargo}"
    LSPMUX_BIN="${CARGO_HOME}/bin/lspmux"
fi

if [ ! -x "${LSPMUX_BIN}" ]; then
    printf '%s\n' "Install via: cargo install --locked lspmux" >&2
    printf '%s\n' "Or set LSPMUX_PATH to the binary location" >&2
    die "lspmux not found"
fi

exec "${LSPMUX_BIN}" "$@"
