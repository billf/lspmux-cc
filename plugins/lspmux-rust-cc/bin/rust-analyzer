#!/usr/bin/env bash
set -euo pipefail

# Wrapper to locate the rust-analyzer binary.
# Priority:
#   1. RUST_ANALYZER_PATH env var (explicit override)
#   2. rust-analyzer on PATH

die() { printf 'ERROR: %s\n' "$*" >&2; exit 1; }

if [ -n "${RUST_ANALYZER_PATH:-}" ] && [ -x "${RUST_ANALYZER_PATH}" ]; then
    exec "${RUST_ANALYZER_PATH}" "$@"
fi

if command -v rust-analyzer >/dev/null 2>&1; then
    exec rust-analyzer "$@"
fi

printf '%s\n' "Set RUST_ANALYZER_PATH or add rust-analyzer to PATH." >&2
printf '%s\n' "Nix example: nix build .#rust-analyzer" >&2
die "rust-analyzer not found"
